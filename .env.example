# Public base URL where search index artifacts are served.
# Local default in code: /api/texoro/index
PUBLIC_TEXORO_INDEX_BASE_URL=

# Public base URL where TXT files are served.
# Local default in code: /api/texoro/texts
PUBLIC_TEXORO_TEXTS_BASE_URL=
# Password gate for preview / staging access.
# Leave empty to disable the access screen.
SITE_ACCESS_PASSWORD=etso2.0
