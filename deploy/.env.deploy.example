# Cloudflare R2
R2_ACCOUNT_ID="tu_account_id"
R2_ACCESS_KEY_ID="tu_access_key_id"
R2_SECRET_ACCESS_KEY="tu_secret_access_key"

# Alternativa si prefieres un perfil local de AWS CLI en vez de keys en este archivo:
# AWS_PROFILE="r2-etso-deploy"

# Turso
TURSO_DB_NAME="etso-prod"
# Windows only, when Turso CLI is installed inside WSL.
TURSO_WSL_DISTRO="Ubuntu"

# Rutas temporales dentro de deploy/input
SQLITE_LOCAL_PATH="deploy/input/turso/etso.sqlite"

# Indice de busqueda generado durante deploy-all
SEARCH_INDEX_INPUT_PATH="deploy/input/private-assets/texts"
SEARCH_INDEX_OUTPUT_PATH="deploy/input/public-assets/search"
SEARCH_INDEX_COMPACT="true"
SEARCH_INDEX_NODE_MAX_OLD_SPACE_SIZE="8192"

# Opcional
DEPLOY_HOOK_URL=""
