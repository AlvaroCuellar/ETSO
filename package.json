{
	"name": "etso",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"engines": {
		"node": "24.x"
	},
	"scripts": {
		"dev": "npm run build:catalog && vite dev",
		"build": "npm run build:catalog && vite build",
		"build:catalog": "node scripts/build-catalog-snapshot.mjs",
		"preview": "vite preview",
		"prepare": "node scripts/build-catalog-snapshot.mjs && svelte-kit sync",
		"check": "npm run build:catalog && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "npm run build:catalog && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"index:texts": "node scripts/build-search-index.mjs",
		"index:texts:compact": "node scripts/build-search-index.mjs --compact",
		"index:validate": "node scripts/validate-search-index.mjs"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^25.6.0",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.2.2",
		"typescript": "^6.0.2",
		"vite": "^8.0.7"
	},
	"dependencies": {
		"echarts": "^6.0.0",
		"lucide-svelte": "^1.0.1"
	}
}
